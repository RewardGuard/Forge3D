{
  "name": "forge3d",
  "version": "0.1.3",
  "description": "Forge3D — AI 3D design + circuit simulator + sticker-circuit exporter",
  "author": "Forge3D",
  "license": "MIT",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "icon": "node scripts/make-app-icon.mjs",
    "dist": "npm run icon && npm run build && electron-builder --mac dmg",
    "dist:signed": "npm run icon && npm run build && electron-builder --mac dmg --config.mac.notarize=true",
    "start": "cross-env NODE_ENV=development electron .",
    "test": "node scripts/benchmark-sim.mjs && node scripts/acceptance-orchestra.mjs",
    "test:acceptance": "node scripts/acceptance-orchestra.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "three-bvh-csg": "^0.0.18",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.forge3d.app",
    "productName": "Forge3D",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "Forge3D Installer"
    }
  }
}
