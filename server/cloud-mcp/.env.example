# Forge3D Cloud — configuration. Copy to .env (gitignored) or run `npm run setup`.
# Each var notes WHERE to get its value.

# --- server ---
# Port the Node process listens on (Caddy/nginx proxies HTTPS → this).
PORT=8788
# Your PUBLIC https URL. WHERE: a subdomain you own (e.g. mcp.forge3d.app) with a
# DNS A-record pointing at your server's public IP.
FORGE3D_PUBLIC_URL=https://mcp.forge3d.app

# --- single-tenant secrets (just you + your own desktop) ---
# Bearer token MCP clients must send. WHERE: generate one (`npm run setup` does it,
# or: openssl rand -hex 24). You paste it when adding the connector in Claude.
FORGE3D_API_TOKEN=
# Pairing token the desktop app presents. WHERE: generate one (as above). You paste
# it into Forge3D → Settings → Orchestra AI → Forge3D Cloud.
FORGE3D_PAIR_TOKEN=

# --- OAuth 2.1 (only needed to list in Claude's directory; leave blank otherwise) ---
# Your identity provider's issuer URL. WHERE: after creating a tenant/app at an IdP
# (Auth0/Stytch/WorkOS/Clerk/Keycloak). e.g. https://YOUR.us.auth0.com/
FORGE3D_OAUTH_ISSUER=
# JWKS (public keys) URL used to verify access tokens. WHERE: almost always
# <issuer>/.well-known/jwks.json — your IdP's discovery doc lists the exact URL.
FORGE3D_OAUTH_JWKS=
